{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@modelcontextprotocol/server": ["./node_modules/@modelcontextprotocol/server/src/index.ts"],
      "@modelcontextprotocol/server/_shims": [
        "./node_modules/@modelcontextprotocol/server/src/shimsNode.ts"
      ],
      "@modelcontextprotocol/core": [
        "./node_modules/@modelcontextprotocol/server/node_modules/@modelcontextprotocol/core/src/index.ts"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
